{
  "name": "big-small-dashboard",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "vite",
    "api:generate": "openapi-typescript src/api/generated/openapi.json -o src/api/generated/schema.d.ts",
    "api:check": "npm run api:generate && git diff --exit-code src/api/generated/schema.d.ts",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"tests/**/*.ts\"",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "build": "vite build",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@ant-design/icons": "6.1.0",
    "@tanstack/react-query": "5.101.0",
    "antd": "6.4.4",
    "echarts": "6.1.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.10.1"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^24.10.2",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.24",
    "jsdom": "29.1.1",
    "openapi-typescript": "7.13.0",
    "prettier": "3.8.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.1",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  }
}
