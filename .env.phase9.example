RUNTIME_PROFILE=simulation
SIM_BACKEND=mujoco
SIM_HEADLESS=true
SIM_ROBOT_PROFILE=franka_panda
SIM_SCENE_PROFILE=desktop_pick_place
SIM_SEED=0
SIM_PHYSICS_DT=0.0041666667
SIM_CONTROL_DT=0.02
SIM_SENSOR_DT=0.0333333333
SIM_REALTIME_FACTOR=0
SIM_MAX_EPISODE_SECONDS=60
SIM_DOMAIN_RANDOMIZATION=true
SIM_RENDER_RGB=false
SIM_RENDER_DEPTH=false
SIM_RECORD_VIDEO=false
SIM_ARTIFACT_DIR=experiments/results/phase9

MUJOCO_GL=egl
MUJOCO_MODEL_PATH=assets/robots/franka_panda/scene.xml

ISAAC_SIM_ROOT=
ISAAC_SIM_HEADLESS=true
ISAAC_SIM_ASSET_ROOT=
ISAAC_SIM_STAGE_PATH=
ISAAC_SIM_RENDER_WIDTH=640
ISAAC_SIM_RENDER_HEIGHT=480

ROS_DISTRO=jazzy
ROS_DOMAIN_ID=42
RMW_IMPLEMENTATION=rmw_fastrtps_cpp
USE_SIM_TIME=true
ROS2_WS=ros2_ws
MOVEIT_CONFIG_PACKAGE=bigsmall_franka_moveit_config

PLANNER_BACKEND=rule_based
REPLANNER_BACKEND=rule_based

