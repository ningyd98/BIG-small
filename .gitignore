# 忽略规则说明：排除本地缓存、运行数据库、前端构建和仿真大文件，避免提交敏感或生成数据。
.DS_Store

# Python bytecode and local tool caches
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Virtual environments and editable package metadata
.venv/
*.egg-info/

# Local runtime data and generated experiment outputs
.env.local
