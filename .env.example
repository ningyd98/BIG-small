APP_NAME=BIG-small
APP_ENV=development
RUNTIME_PROFILE=test
DATABASE_URL=sqlite:///./data/robot_control.db
MQTT_BROKER_URL=mqtt://localhost:1883
CLOUD_SUPERVISION_PERIOD_MS=1000
COMMAND_TTL_MS=2500
NETWORK_LOSS_GRACE_MS=3000
SAFETY_SHIELD_ENABLED=true
LOG_LEVEL=INFO
