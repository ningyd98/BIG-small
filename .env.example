APP_NAME=BIG-small
APP_ENV=development
RUNTIME_PROFILE=test
DATABASE_URL=sqlite:///./data/robot_control.db
MQTT_BROKER_URL=mqtt://localhost:1883
CLOUD_SUPERVISION_PERIOD_MS=1000
COMMAND_TTL_MS=2500
NETWORK_LOSS_GRACE_MS=3000
SAFETY_SHIELD_ENABLED=true
LOG_LEVEL=INFO
# Phase 4 cloud planner (only needed for OpenAICompatiblePlannerAdapter)
# PLANNER_API_ENDPOINT=https://api.openai.com/v1/chat/completions
# PLANNER_API_KEY=sk-...
# PLANNER_MODEL=gpt-4o-mini

# Phase 6.1 event autonomy persistence and replanning
EVENT_AUTONOMY_REPOSITORY=sqlite
EVENT_AUTONOMY_DATABASE_URL=sqlite:///./data/event_autonomy.db
EVENT_AUTONOMY_MAX_LOCAL_RETRIES=3
OUTBOX_POLL_INTERVAL_MS=1000
# REPLANNER_API_ENDPOINT=https://planner.internal/v1/chat/completions
# REPLANNER_API_KEY=secret-placeholder
# REPLANNER_MODEL=phase6-replanner

# Required when RUNTIME_PROFILE=production
# ROBOT_ADAPTER=real_robot_sdk
# TELEMETRY_PROVIDER=robot_sdk
# SCENE_STATE_PROVIDER=vision_pipeline
# SUPERVISION_REPOSITORY=sqlite
# SUPERVISION_SCHEDULER=asyncio
# EVENT_AUTONOMY_REPOSITORY=sqlite
# EVENT_AUTONOMY_DATABASE_URL=sqlite:////var/lib/big-small/event_autonomy.db
# REPLANNER_API_ENDPOINT=https://planner.internal/v1/chat/completions
# REPLANNER_API_KEY=secret-placeholder
